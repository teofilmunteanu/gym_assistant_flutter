    "version": "0.2.0",
        "configurations": [
        {
            "name": "Run on Medium_Phone_API_35(no debug)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "preLaunchTask": "wait-for-emulator",
            "flutterMode": "release",
            "noDebug": true,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run (simple) on Medium_Phone_API_35(no debug)",
            "type": "dart",
            "request": "launch",
            "preLaunchTask": "run-on-medium-emulator-simple"
        },
        {
            "name": "Debug on Medium_Phone_API_35",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "preLaunchTask": "wait-for-emulator",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "gym_assistant_flutter",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "gym_assistant_flutter (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "gym_assistant_flutter (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}